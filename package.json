{
  "name": "mail2tg",
  "version": "0.1.1",
  "description": "CLI to configure Email to Telegram routing via Cloudflare",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mail2tg": "dist/index.js"
  },
  "files": [
    "dist",
    "src/worker-template"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build"
  },
  "keywords": [
    "cloudflare",
    "telegram",
    "email-routing",
    "cli",
    "automation"
  ],
  "author": "mail2tg contributors",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "postal-mime": "^2.7.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.73.0"
  }
}
